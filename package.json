{
  "name": "lepapier",
  "version": "0.1.14",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "docs:dev": "node scripts/dev-docs.mjs",
    "docs:build": "npm run docs:social-card && astro build --config astro.docs.config.mjs --force",
    "docs:preview": "npm run pages:build && astro preview --config astro.docs.config.mjs --host 127.0.0.1",
    "docs:social-card": "node scripts/generate-social-card.mjs",
    "pages:build": "npm run pages:build:release",
    "pages:build:docs": "npm run docs:build",
    "pages:build:release": "npm run build && npm run docs:build && node scripts/copy-editor-build.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "release:tag": "node scripts/create-release-tag.mjs",
    "release:validate-tag": "node scripts/validate-release-tag.mjs",
    "release:zip": "node scripts/create-release-zip.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:install-deps": "playwright install --with-deps chromium",
    "test:e2e:prod": "playwright test --config=playwright.production.config.ts",
    "test:e2e:prod:headed": "playwright test --config=playwright.production.config.ts --headed",
    "test:e2e:prod:server": "node scripts/serve-production-e2e.mjs",
    "ci:install-playwright": "npm run test:e2e:install-deps",
    "ci:verify": "npm run verify && npm run test:e2e:prod",
    "ci:build-app": "npm run build",
    "ci:build-docs": "npm run pages:build:docs",
    "ci:release-validate-tag": "npm run release:validate-tag",
    "ci:release-package": "npm run build && npm run release:zip",
    "ci:release-notes": "node scripts/generate-release-notes.mjs",
    "ci:build-pages-release": "npm run pages:build:release",
    "ci:validate-pages-editor": "node scripts/validate-editor-version.mjs dist/docs/editor/index.html",
    "verify": "npm run check && npm test && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "astro": "^6.4.6",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.7"
  }
}
