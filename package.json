{
  "name": "lepapier",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "docs:dev": "node scripts/dev-docs.mjs",
    "docs:build": "npm run docs:social-card && astro build --config astro.docs.config.mjs --force",
    "docs:preview": "npm run pages:build && astro preview --config astro.docs.config.mjs --host 127.0.0.1",
    "docs:social-card": "node scripts/generate-social-card.mjs",
    "pages:build": "npm run pages:build:release",
    "pages:build:docs": "npm run docs:build",
    "pages:build:release": "npm run build && npm run docs:build && node scripts/copy-editor-build.mjs",
    "release:validate-tag": "node scripts/validate-release-tag.mjs",
    "release:zip": "node scripts/create-release-zip.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run check && npm test"
  },
  "devDependencies": {
    "@fontsource/geist": "^5.2.9",
    "@types/node": "^25.9.1",
    "astro": "^6.4.6",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.7"
  }
}
